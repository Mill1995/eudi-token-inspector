{
  "id": "request-pex",
  "kind": "openid4vp-request",
  "description": "Justified age-verification request in Presentation Exchange shape: a single age_over_18 assertion, nothing else. The clean baseline and the PEX parser vector.",
  "request": {
    "response_type": "vp_token",
    "response_mode": "direct_post",
    "client_id": "https://verifier.eudi.example",
    "nonce": "9c8f2b1a-77e0-4f2a-9a1e-d3c2b1a09f88",
    "presentation_definition": {
      "id": "age-check",
      "purpose": "Confirm you are over 18 to enter",
      "input_descriptors": [
        {
          "id": "pid-age",
          "format": {
            "dc+sd-jwt": {
              "sd-jwt_alg_values": ["ES256"],
              "kb-jwt_alg_values": ["ES256"]
            }
          },
          "constraints": {
            "limit_disclosure": "required",
            "fields": [
              {
                "path": ["$.vct"],
                "filter": {
                  "type": "string",
                  "const": "urn:eudi:pid:1"
                }
              },
              {
                "path": ["$.age_over_18"]
              }
            ]
          }
        }
      ]
    }
  },
  "expect": {
    "overaskingRuleIds": []
  }
}
