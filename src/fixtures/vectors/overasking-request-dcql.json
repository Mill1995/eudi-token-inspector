{
  "id": "overasking-request-dcql",
  "kind": "openid4vp-request",
  "description": "Remote age-verification request that over-asks: exact birthdate (an age_over_18 assertion would suffice), a portrait in a remote flow, and a unique document_number.",
  "request": {
    "response_type": "vp_token",
    "response_mode": "direct_post",
    "client_id": "https://bar.example",
    "nonce": "n-0S6_WzA2Mj",
    "purpose": "Confirm you are over 18 to enter",
    "dcql_query": {
      "credentials": [
        {
          "id": "pid",
          "format": "dc+sd-jwt",
          "meta": {
            "vct_values": ["urn:eudi:pid:1"]
          },
          "claims": [
            {
              "path": ["birthdate"]
            },
            {
              "path": ["portrait"]
            },
            {
              "path": ["document_number"]
            }
          ]
        }
      ]
    }
  },
  "expect": {
    "overaskingRuleIds": [
      "exact-birthdate-when-age-assertion-suffices",
      "portrait-in-remote-flow",
      "unique-identifier-maximises-linkability"
    ]
  }
}
