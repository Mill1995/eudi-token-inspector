{
  "name": "eudi-token-inspector",
  "version": "0.0.0",
  "private": true,
  "description": "A client-side inspector for EUDI Wallet presentation artifacts (SD-JWT VC + OpenID4VP). Decode, verify locally, check trust, flag overasking. Zero backend.",
  "homepage": "https://eudi-inspector.yannickjourney.com",
  "license": "Apache-2.0",
  "author": "Yannick Müller",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mill1995/eudi-token-inspector"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "deploy": "wrangler deploy"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "happy-dom": "20.10.6",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "tailwindcss": "4.3.2",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.10",
    "wrangler": "4.107.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.5.2"
}
